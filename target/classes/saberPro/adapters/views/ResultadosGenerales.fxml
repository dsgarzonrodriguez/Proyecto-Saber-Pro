<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="saberPro.adapters.controllers.ResultadosGeneralesController"
            style="-fx-background-color: #f4f6fb;">

    <top>
        <HBox style="-fx-background-color: #1a2a6c; -fx-padding: 16 24;">
            <Label text="Resultados Generales Saber Pro"
                   style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold;"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="16" style="-fx-padding: 24;">

            <!-- Filtros -->
            <HBox spacing="12" alignment="CENTER_LEFT"
                  style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, #c0c8e0, 6, 0, 0, 2);">

                <VBox spacing="4" prefWidth="90">
                    <Label text="Año" style="-fx-font-size: 11px; -fx-text-fill: #666;"/>
                    <TextField fx:id="txtAnio" promptText="2024"
                               style="-fx-pref-height: 34px; -fx-border-color: #c0c8e0; -fx-border-radius: 5; -fx-background-radius: 5;"/>
                </VBox>

                <VBox spacing="4" prefWidth="110">
                    <Label text="Semestre" style="-fx-font-size: 11px; -fx-text-fill: #666;"/>
                    <ComboBox fx:id="cbxSemestre" maxWidth="Infinity"
                              style="-fx-pref-height: 34px;"/>
                </VBox>

                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="Programa" style="-fx-font-size: 11px; -fx-text-fill: #666;"/>
                    <ComboBox fx:id="cbxPrograma" maxWidth="Infinity"
                              style="-fx-pref-height: 34px;"/>
                </VBox>

                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="Ciudad" style="-fx-font-size: 11px; -fx-text-fill: #666;"/>
                    <ComboBox fx:id="cbxCiudad" maxWidth="Infinity"
                              style="-fx-pref-height: 34px;"/>
                </VBox>

                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="Módulo" style="-fx-font-size: 11px; -fx-text-fill: #666;"/>
                    <ComboBox fx:id="cbxModulo" maxWidth="Infinity"
                              style="-fx-pref-height: 34px;"/>
                </VBox>

                <VBox spacing="4" alignment="BOTTOM_LEFT">
                    <Label text=" "/>
                    <HBox spacing="8">
                        <Button text="Consultar"  onAction="#onConsultar"
                                style="-fx-background-color: #1a2a6c; -fx-text-fill: white; -fx-pref-height: 34px; -fx-pref-width: 95px; -fx-background-radius: 6; -fx-cursor: hand;"/>
                        <Button text="PDF"        onAction="#onExportarPDF"
                                style="-fx-background-color: #dc3545; -fx-text-fill: white; -fx-pref-height: 34px; -fx-pref-width: 70px; -fx-background-radius: 6; -fx-cursor: hand;"/>
                        <Button text="Excel"      onAction="#onExportarExcel"
                                style="-fx-background-color: #28a745; -fx-text-fill: white; -fx-pref-height: 34px; -fx-pref-width: 70px; -fx-background-radius: 6; -fx-cursor: hand;"/>
                        <Button text="Limpiar"    onAction="#onLimpiar"
                                style="-fx-background-color: #6c757d; -fx-text-fill: white; -fx-pref-height: 34px; -fx-pref-width: 80px; -fx-background-radius: 6; -fx-cursor: hand;"/>
                    </HBox>
                </VBox>
            </HBox>

            <!-- Tabla resultados -->
            <TableView fx:id="tablaResultados" VBox.vgrow="ALWAYS"
                       style="-fx-background-color: white; -fx-background-radius: 10;">
                <columns>
                    <TableColumn fx:id="colNombre"    text="Nombre"    prefWidth="120"/>
                    <TableColumn fx:id="colApellido"  text="Apellido"  prefWidth="120"/>
                    <TableColumn fx:id="colCc"        text="CC"        prefWidth="100"/>
                    <TableColumn fx:id="colRegistro"  text="Registro"  prefWidth="100"/>
                    <TableColumn fx:id="colAnio"      text="Año"       prefWidth="60"/>
                    <TableColumn fx:id="colSemestre"  text="Semestre"  prefWidth="80"/>
                    <TableColumn fx:id="colPrograma"  text="Programa"  prefWidth="160"/>
                    <TableColumn fx:id="colCiudad"    text="Ciudad"    prefWidth="100"/>
                    <TableColumn fx:id="colPuntaje"   text="P. Global" prefWidth="90"/>
                    <TableColumn fx:id="colPercentil" text="Percentil" prefWidth="80"/>
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                </columnResizePolicy>
            </TableView>

        </VBox>
    </center>
</BorderPane>
