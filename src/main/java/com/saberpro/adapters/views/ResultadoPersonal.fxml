<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.saberpro.adapters.controllers.ResultadoPersonalController"
            style="-fx-background-color: #f4f6fb;">

    <top>
        <HBox style="-fx-background-color: #1a2a6c; -fx-padding: 16 24;">
            <Label text="Resultado Personal Saber Pro"
                   style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold;"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="16" style="-fx-padding: 24;">

            <!-- Búsqueda -->
            <HBox spacing="12" alignment="CENTER_LEFT"
                  style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, #c0c8e0, 6, 0, 0, 2);">

                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="Nombre del estudiante" style="-fx-font-size: 11px; -fx-text-fill: #666;"/>
                    <TextField fx:id="txtNombre" promptText="Buscar por nombre..."
                               style="-fx-pref-height: 34px; -fx-border-color: #c0c8e0; -fx-border-radius: 5; -fx-background-radius: 5;"/>
                </VBox>

                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="Cédula (CC)" style="-fx-font-size: 11px; -fx-text-fill: #666;"/>
                    <TextField fx:id="txtCc" promptText="Buscar por CC..."
                               style="-fx-pref-height: 34px; -fx-border-color: #c0c8e0; -fx-border-radius: 5; -fx-background-radius: 5;"/>
                </VBox>

                <VBox spacing="4" alignment="BOTTOM_LEFT">
                    <Label text=" "/>
                    <HBox spacing="8">
                        <Button text="Buscar"  onAction="#onBuscarEstudiante"
                                style="-fx-background-color: #1a2a6c; -fx-text-fill: white; -fx-pref-height: 34px; -fx-pref-width: 90px; -fx-background-radius: 6; -fx-cursor: hand;"/>
                        <Button text="Limpiar" onAction="#onLimpiar"
                                style="-fx-background-color: #6c757d; -fx-text-fill: white; -fx-pref-height: 34px; -fx-pref-width: 90px; -fx-background-radius: 6; -fx-cursor: hand;"/>
                    </HBox>
                </VBox>
            </HBox>

            <!-- Tabla estudiantes + Panel resultado (lado a lado) -->
            <HBox spacing="16" VBox.vgrow="ALWAYS">

                <!-- Tabla de estudiantes encontrados -->
                <VBox spacing="8" HBox.hgrow="ALWAYS">
                    <Label text="Estudiantes encontrados"
                           style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #1a2a6c;"/>
                    <TableView fx:id="tablaEstudiantes" VBox.vgrow="ALWAYS"
                               onMouseClicked="#onSeleccionarEstudiante"
                               style="-fx-background-color: white; -fx-background-radius: 10;">
                        <columns>
                            <TableColumn fx:id="colNombre"   text="Nombre"   prefWidth="110"/>
                            <TableColumn fx:id="colApellido" text="Apellido" prefWidth="110"/>
                            <TableColumn fx:id="colCc"       text="CC"       prefWidth="100"/>
                            <TableColumn fx:id="colRegistro" text="Registro" prefWidth="90"/>
                            <TableColumn fx:id="colAnio"     text="Año"      prefWidth="55"/>
                            <TableColumn fx:id="colSemestre" text="Sem."     prefWidth="50"/>
                        </columns>
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                        </columnResizePolicy>
                    </TableView>
                </VBox>

                <!-- Panel de resultado personal -->
                <VBox spacing="12" prefWidth="340"
                      style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, #c0c8e0, 6, 0, 0, 2);">

                    <Label text="Resultado del Estudiante"
                           style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #1a2a6c;"/>

                    <GridPane hgap="12" vgap="8">
                        <Label text="Puntaje Global:" GridPane.columnIndex="0" GridPane.rowIndex="0"
                               style="-fx-font-size: 12px; -fx-text-fill: #666;"/>
                        <Label fx:id="lblPuntajeGlobal" text="-" GridPane.columnIndex="1" GridPane.rowIndex="0"
                               style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #1a2a6c;"/>

                        <Label text="Percentil Global:" GridPane.columnIndex="0" GridPane.rowIndex="1"
                               style="-fx-font-size: 12px; -fx-text-fill: #666;"/>
                        <Label fx:id="lblPercentilGlobal" text="-" GridPane.columnIndex="1" GridPane.rowIndex="1"
                               style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #1a2a6c;"/>

                        <Label text="Programa:" GridPane.columnIndex="0" GridPane.rowIndex="2"
                               style="-fx-font-size: 12px; -fx-text-fill: #666;"/>
                        <Label fx:id="lblPrograma" text="-" GridPane.columnIndex="1" GridPane.rowIndex="2"
                               style="-fx-font-size: 12px; -fx-text-fill: #333;"/>

                        <Label text="Ciudad:" GridPane.columnIndex="0" GridPane.rowIndex="3"
                               style="-fx-font-size: 12px; -fx-text-fill: #666;"/>
                        <Label fx:id="lblCiudad" text="-" GridPane.columnIndex="1" GridPane.rowIndex="3"
                               style="-fx-font-size: 12px; -fx-text-fill: #333;"/>
                    </GridPane>

                    <Separator/>

                    <Label text="Resultados por módulo"
                           style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #555;"/>

                    <TableView fx:id="tablaModulos" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colModulo"         text="Módulo"    prefWidth="140"/>
                            <TableColumn fx:id="colPuntajeModulo"  text="Puntaje"   prefWidth="70"/>
                            <TableColumn fx:id="colPercentilModulo" text="Percentil" prefWidth="70"/>
                        </columns>
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                        </columnResizePolicy>
                    </TableView>
                </VBox>
            </HBox>

        </VBox>
    </center>
</BorderPane>
