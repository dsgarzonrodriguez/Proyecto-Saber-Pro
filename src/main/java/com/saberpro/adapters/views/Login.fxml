<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.saberpro.adapters.controllers.LoginController"
      alignment="CENTER"
      spacing="0"
      style="-fx-background-color: #1a2a6c;">

    <!-- Encabezado -->
    <VBox alignment="CENTER" style="-fx-background-color: #1a2a6c;" VBox.vgrow="ALWAYS">
        <padding><Insets top="40" bottom="20"/></padding>
        <Label text="SABER PRO"
               style="-fx-text-fill: white; -fx-font-size: 32px; -fx-font-weight: bold;"/>
        <Label text="Universidad de los Llanos"
               style="-fx-text-fill: #aec6f0; -fx-font-size: 14px;"/>
    </VBox>

    <!-- Tarjeta de login -->
    <VBox alignment="CENTER" spacing="16"
          style="-fx-background-color: white; -fx-background-radius: 16 16 0 0; -fx-padding: 40 50 40 50;">

        <Label text="Iniciar Sesión"
               style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1a2a6c;"/>

        <VBox spacing="6">
            <Label text="Correo electrónico"
                   style="-fx-font-size: 12px; -fx-text-fill: #555;"/>
            <TextField fx:id="txtCorreo" promptText="usuario@unillanos.edu.co"
                       style="-fx-pref-height: 38px; -fx-border-color: #c0c8e0; -fx-border-radius: 6; -fx-background-radius: 6; -fx-font-size: 13px;"/>
        </VBox>

        <VBox spacing="6">
            <Label text="Contraseña"
                   style="-fx-font-size: 12px; -fx-text-fill: #555;"/>
            <PasswordField fx:id="txtContrasena" promptText="••••••••"
                           style="-fx-pref-height: 38px; -fx-border-color: #c0c8e0; -fx-border-radius: 6; -fx-background-radius: 6; -fx-font-size: 13px;"/>
        </VBox>

        <Button text="INGRESAR" onAction="#onIniciarSesion"
                maxWidth="Infinity"
                style="-fx-background-color: #1a2a6c; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-pref-height: 42px; -fx-background-radius: 8; -fx-cursor: hand;"/>

        <Hyperlink text="¿Olvidaste tu contraseña?" onAction="#onRecuperar"
                   style="-fx-text-fill: #1a2a6c; -fx-font-size: 12px; -fx-border-color: transparent;"/>

        <VBox.margin><Insets top="10"/></VBox.margin>
    </VBox>
</VBox>
